<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.kclm.owep.mapper.CourseMapper">
    <resultMap id="BaseMap" type="Course">
        <id column="id" jdbcType="INTEGER" property="id" />
        <result column="course_number" jdbcType="VARCHAR" property="courseNumber" />
        <result column="course_name" jdbcType="VARCHAR" property="courseName" />
        <result column="start_time" jdbcType="TIMESTAMP" property="startTime" />
        <result column="end_time" jdbcType="TIMESTAMP" property="endTime" />
        <result column="course_period" jdbcType="INTEGER" property="coursePeriod" />
        <result column="course_status" jdbcType="INTEGER" property="courseStatus" />
        <result column="course_image" jdbcType="VARCHAR" property="courseImage" />
        <result column="course_desc" jdbcType="VARCHAR" property="courseDesc" />
        <result column="create_time" jdbcType="TIMESTAMP" property="createTime" />
        <result column="course_open_status" jdbcType="INTEGER" property="courseOpenStatus" />
        <result column="free" jdbcType="TINYINT" property="free" />
        <result column="hot" jdbcType="TINYINT" property="hot" />
        <result column="listener" jdbcType="TINYINT" property="listener" />
        <result column="course_type" jdbcType="VARCHAR" property="courseType" />
        <result column="course_send_type" jdbcType="VARCHAR" property="courseSendType" />
        <result column="is_delete" jdbcType="INTEGER" property="isDelete" />
        <result column="version" jdbcType="INTEGER" property="version" />
        <result column="last_access_time" jdbcType="TIMESTAMP" property="lastAccessTime" />
    </resultMap>

    <sql id="Base_Column_List">
        id, course_number, course_name, start_time, end_time, course_period, course_status,
        course_image, course_desc, create_time, course_open_status, free, hot, listener, course_type,
        course_send_type, is_delete, version, last_access_time
    </sql>

    <select id="selectByPlanId" resultMap="PlanCourseMap">
        select c.id cid, course_number, course_name
        from t_course c join t_planmanager_course pc on c.id = pc.fk_course_id
        where pc.fk_planmanager_id = #{planId} and c.is_delete = 1 and c.course_status = 1 and pc.is_delete = 1
    </select>

    <resultMap id="PlanCourseMap" type="Course">
        <id column="cid" jdbcType="INTEGER" property="id" />
        <result column="course_number" jdbcType="VARCHAR" property="courseNumber" />
        <result column="course_name" jdbcType="VARCHAR" property="courseName" />
    </resultMap>

    <select id="selectAll" resultMap="BaseMap">
        select
        <include refid="Base_Column_List" />
        from t_course
        where is_delete = 1
    </select>

    <select id="selectCourseByClassId" resultMap="selectCourseByClassIdMap">
        select
        co.id coid,
        course_name
        from t_class c join t_class_planmanager cp on c.id = cp.fk_class_id join t_planmanager_course pc on cp.fk_plan_id = pc.fk_planmanager_id join t_course co on pc.fk_course_id = co.id
        <where>
            <if test="classId != null ">
                c.id = #{classId}
            </if>
            and c.is_delete = 1 and pc.is_delete = 1 and co.is_delete = 1
        </where>
    </select>

    <resultMap id="selectCourseByClassIdMap" type="Course">
        <id column="coid" jdbcType="INTEGER" property="id" />
        <result column="course_name" jdbcType="VARCHAR" property="courseName" />
    </resultMap>
</mapper>