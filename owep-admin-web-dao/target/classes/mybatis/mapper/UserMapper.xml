            </if>
            <if test="lastAccessTime != null">
                last_access_time = #{lastAccessTime,jdbcType=TIMESTAMP},
            </if>
            <if test="version != null">
                version = #{version,jdbcType=INTEGER},
            </if>
        </set>
        where id = #{id,jdbcType=INTEGER}
    </update>

    <select id="selectByName" resultType="com.kclm.owep.entity.User">
        select
        <include refid="Base_Column_List" />
        from t_user
        where user_name = #{userName}
    </select>

    <select id="getGroupId" resultType="INTEGER">
        select
            group_id as gid
        from t_user_group
        where user_id = #{id}

    </select>

    <insert id="attachGroupToUser">
        insert into t_user_group(user_id, group_id) value(#{uid},#{gid})
    </insert>

    <select id="selectByType" resultType="com.kclm.owep.entity.User">
        select
        <include refid="Base_Column_List" />
        from t_user
        where user_type =  #{type} and is_delete = 1
    </select>

    <select id="getUserByUserName" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List" />
        from t_user
        where user_name = #{userName}
    </select>

    <!--分隔点-->

    <select id="selectUserByuserNameAndrealName" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List" />
        from t_user
        where user_name = #{userName} and real_name = #{realName} and user_type = #{userType,jdbcType=INTEGER} and is_delete = 1
    </select>

    <select id="selectGroupsByUserId" resultMap="UserGroup">
        select u.id uid,
        user_name,
        user_pwd,
        user_phone,
        real_name,
        user_email,
        email_code,
        gender,
        card_num,
        status,
        effective_date,
        user_type,
        birth,
        image_url,
        description,
        title,
        perfect_status,
        is_delete,
        u.create_time u_create_time,
        u.last_access_time u_last_access_time,
        u.version u_version,
        g.id gid,
        group_name,
        group_description,
        g.create_time g_create_time,
        g.last_access_time g_last_access_time,
        g.version g_version,
        max_count
        from t_user u
        left join t_user_group ug on u.id = ug.user_id
        left join t_group g on ug.group_id = g.id
        <where>
            <if test="userId != null and userId != 0">
                u.id = #{userId}
            </if>
        </where>
    </select>
    <resultMap id="UserGroup" type="com.kclm.owep.entity.User">
        <id property="id" column="uid"/>
        <result property="userName" column="user_name"/>
        <result property="userPwd" column="user_pwd"/>
        <result property="userPhone" column="user_phone"/>
        <result property="realName" column="real_name"/>
        <result property="userEmail" column="user_email"/>
        <result property="emailCode" column="email_code"/>
        <result property="gender" column="gender"/>
        <result property="cardNum" column="card_num"/>
        <result property="status" column="status"/>
        <result property="effectiveDate" column="effective_date"/>
        <result property="userType" column="user_type"/>
        <result property="birth" column="birth"/>
        <result property="imageUrl" column="image_url"/>
        <result property="description" column="description"/>
        <result property="title" column="title"/>
        <result property="perfectStatus" column="perfect_status"/>
        <result property="isDelete" column="is_delete"/>
        <result property="createTime" column="u_create_time"/>
        <result property="lastAccessTime" column="u_last_access_time"/>
        <result property="version" column="u_version"/>
        <collection property="groups" ofType="com.kclm.owep.entity.Group">
            <id property="id" column="gid"/>
            <result property="groupName" column="group_name"/>
            <result property="groupDescription" column="group_description"/>
            <result property="createTime" column="g_create_time"/>
            <result property="lastAccessTime" column="g_last_access_time"/>
            <result property="version" column="g_version"/>
            <result property="maxCount" column="max_count"/>
        </collection>
    </resultMap>

    <update id="switchStatus" parameterType="Integer">
        update t_user set status = #{status}
        where id = #{id}
    </update>

    <delete id="deleteByUserIdInUG">
        delete
        from t_user_group
        where
        <foreach collection="list" item="item" separator="or">
            user_id = #{item}
        </foreach>
    </delete>

    <select id="getUserByTeacherRealName" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List" />
        from t_user
        where real_name = #{realName} and user_type = 3 and is_delete = 1
    </select>
</mapper>