<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.kclm.owep.mapper.SysLogMapper">

    <insert id="save">
        insert into t_syslog
        <trim prefix="(" suffix=")" suffixOverrides=",">
        <if test="title != null">
            title,
        </if>
        <if test="moduleName != null">
            module_name,
        </if>
        <if test="ipAddr != null">
            ip_addr,
        </if>
        <if test="method != null">
            method,
        </if>
        <if test="requestUrl != null">
            request_url,
        </if>
        <if test="type != null">
            type,
        </if>
        <if test="loginUserName != null">
            login_user_name,
        </if>
        <if test="lastAccessTime != null">
            last_access_time,
        </if>
        <if test="createTime != null">
            create_time,
        </if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
        <if test="title != null">
            #{title},
        </if>
        <if test="moduleName != null">
            #{moduleName},
        </if>
        <if test="ipAddr != null">
            #{ipAddr},
        </if>
        <if test="method != null">
            #{method},
        </if>
        <if test="requestUrl != null">
            #{requestUrl},
        </if>
        <if test="type != null">
            #{type},
        </if>
        <if test="loginUserName != null">
            #{loginUserName},
        </if>
        <if test="lastAccessTime != null">
            #{lastAccessTime},
        </if>
        <if test="createTime != null">
            #{createTime},
        </if>
        </trim>
    </insert>

    <select id="selectByKeyWords" resultType="SystLog">
        select id,
        title,
        module_name,
        ip_addr,
        method,
        request_url,
        type,
        login_user_name,
        last_access_time,
        create_time
        from t_syslog
        <where>
            <if test="name != null and name != ''">
                login_user_name = #{name}
            </if>
            <if test="start != null and end != null">
                and create_time BETWEEN #{start} AND #{end}
            </if>
        </where>
    </select>

    <select id="selectAll" resultType="SystLog">
        select id,
               title,
               module_name,
               ip_addr,
               method,
               request_url,
               type,
               login_user_name,
               last_access_time,
               create_time
        from t_syslog
    </select>
</mapper>