    <select id="selectStuInfo" resultMap="selectStuInfo">
        select
        s.id sid,
        s.stu_number,
        s.stu_name,
        s.stu_pwd,
        s.stu_real_name,
        s.gender,
        s.stu_phone,
        s.stu_email,
        s.effective_date,
        s.status,
        s.stu_school
        from t_student s left join t_class c on s.fk_class_id = c.id
        <where>
            <if test="className != null">
                AND c.class_name = #{className}
            </if>
            <if test="stuRealName != null">                                                                                       nb
                AND s.stu_real_name = #{stuRealName}
            </if>
            <if test="school != null">
                AND s.stu_school = #{school}
            </if>
            <if test="college != null">
                AND s.stu_college = #{college}
            </if>
            <if test="start != null">
                AND c.start_time <![CDATA[ >= ]]> #{start}
            </if>
            <if test="end != null">
                AND c.end_time <![CDATA[ <= ]]> #{end}
            </if>
            AND s.is_delete = 1 AND c.is_delete = 1
        </where>
    </select>
    <resultMap id="selectStuInfo" type="com.kclm.owep.entity.Student">
    <id column="sid" jdbcType="INTEGER" property="id" />
    <result column="stu_number" jdbcType="VARCHAR" property="stuNumber" />
    <result column="stu_pwd" jdbcType="VARCHAR" property="stuPwd" />
    <result column="stu_real_name" jdbcType="VARCHAR" property="stuRealName" />
    <result column="gender" jdbcType="INTEGER" property="gender" />
    <result column="stu_phone" jdbcType="VARCHAR" property="stuPhone" />
    <result column="stu_email" jdbcType="VARCHAR" property="stuEmail" />
    <result column="status" jdbcType="INTEGER" property="status" />
    </resultMap>

    <update id="update" parameterType="com.kclm.owep.entity.Student">
        update t_student
        <set>
            <if test="stuName != null">
                stu_name = #{stuName,jdbcType=VARCHAR},
            </if>
        <if test="stuPhone != null">
            stu_phone = #{stuPhone,jdbcType=VARCHAR},
        </if>
        <if test="stuEmail != null">
            stu_email = #{stuEmail,jdbcType=VARCHAR},
        </if>
        <if test="stuPwd != null">
            stu_pwd = #{stuPwd,jdbcType=VARCHAR},
        </if>
        <if test="effectiveDate != null">
            effective_date = #{effectiveDate,jdbcType=VARCHAR},
        </if>
        <if test="status != null">
            status = #{status,jdbcType=VARCHAR},
        </if>
        <if test="gender != null">
            gender = #{gender,jdbcType=VARCHAR},
        </if>
        </set>
        where id = #{id,jdbcType=INTEGER}
    </update>

    <select id="getOtherClassNames" resultType="com.kclm.owep.entity.Clazz">
        select class_name from t_class where id NOT IN (select fk_class_id from t_student where id = #{stuId})
        and is_delete = 1
    </select>

    <update id="transferStu" >
        update t_student s join t_class c on s.fk_class_id = c.id set s.fk_class_id = (select id from t_class
        where class_name = #{className}) where s.id = #{stuId}
    </update>

    <update id="switchStatus">
        update t_student set status = #{status}
        where id = #{stuId}
    </update>

    <insert id="insertBatch" parameterType="list">
        insert into t_student
        (<include refid="Base_Column_List"/>)
            values
        <foreach collection="list" item="stu" separator=",">
            (#{stu.id}, #{stu.stuName}, #{stu.stuPwd}, #{stu.stuNumber}, #{stu.stuPhone}, #{stu.stuEmail},
            #{stu.stuRealName}, #{stu.emailCode}, #{stu.gender}, #{stu.cardNum},
            #{stu.status}, #{stu.effectiveDate}, #{stu.birth}, #{stu.imageUrl},
            #{stu.description}, #{stu.stuType}, #{stu.stuSchool}, #{stu.stuCollege},
            #{stu.stuMajor}, #{stu.stuEducation}, #{stu.englishLevel}, #{stu.perfectStatus},
            #{stu.isDelete}, #{stu.createTime}, #{stu.lastAccessTime}, #{stu.version})
        </foreach>
    </insert>

    <insert id="insertBatchByClassId">
        insert into t_student
        (fk_class_id, <include refid="Base_Column_List"/>) <!-- 添加class_id字段 -->
        values
        <foreach collection="studentList" item="stu" separator=",">
            (#{classId}, <!-- 这里设置class_id的值，它是外部传入的 -->
            #{stu.id}, #{stu.stuName}, #{stu.stuPwd}, #{stu.stuNumber}, #{stu.stuPhone},
            #{stu.stuEmail}, #{stu.stuRealName}, #{stu.emailCode}, #{stu.gender},
            #{stu.cardNum}, #{stu.status}, #{stu.effectiveDate}, #{stu.birth},
            #{stu.imageUrl}, #{stu.description}, #{stu.stuType}, #{stu.stuSchool},
            #{stu.stuCollege}, #{stu.stuMajor}, #{stu.stuEducation}, #{stu.englishLevel},
            #{stu.perfectStatus}, #{stu.isDelete}, #{stu.createTime},
            #{stu.lastAccessTime}, #{stu.version})
        </foreach>
    </insert>

    <select id="selectByClassId" resultMap="BaseResultMap" parameterType="Integer">
        select <include refid="Base_Column_List"/>
        from t_student where fk_class_id = #{classId} and is_delete = 1
    </select>

    <select id="selectByClassIdAndKeyword" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from t_student
        <where>
            fk_class_id = #{classId}
            <if test="num != null and num != ''">
                and stu_number = #{num}
            </if>
            <if test="name != null and name != ''">
                and stu_real_name = #{name}
            </if>
            and is_delete = 1
        </where>
    </select>
</mapper>