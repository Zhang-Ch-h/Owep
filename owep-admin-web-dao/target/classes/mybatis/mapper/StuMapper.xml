    <association property="clazz" javaType="com.kclm.owep.entity.Clazz">
        <id column="cid" jdbcType="INTEGER" property="id" />
        <result column="class_number" jdbcType="VARCHAR" property="classNumber" />
        <result column="class_name" jdbcType="VARCHAR" property="className" />
        <result column="start_time" jdbcType="TIMESTAMP" property="startTime" />
        <result column="end_time" jdbcType="TIMESTAMP" property="endTime" />
        <result column="class_status" jdbcType="INTEGER" property="classStatus" />
        <result column="institute_name" jdbcType="VARCHAR" property="instituteName" />
        <result column="branch_name" jdbcType="VARCHAR" property="branchName" />
        <result column="class_desc" jdbcType="VARCHAR" property="classDesc" />
        <result column="teacher_name" jdbcType="VARCHAR" property="teacherName" />
        <result column="c_is_delete" jdbcType="INTEGER" property="isDelete" />
        <result column="c_version" jdbcType="INTEGER" property="version" />
        <result column="c_create_time" jdbcType="TIMESTAMP" property="createTime" />
        <result column="c_last_access_time" jdbcType="TIMESTAMP" property="lastAccessTime" />
        <result column="old_class_name" jdbcType="VARCHAR" property="oldClassName" />
        <result column="old_class_num" jdbcType="VARCHAR" property="oldClassNum" />
    </association>
    </resultMap>

    <select id="isExistClassId" resultType="integer">
        select
        fk_class_id
        from t_student where id = #{stuId}
    </select>

    <update id="updateClassIdByStuId">
        update t_student set fk_class_id = #{classId} where id = #{stuId}
    </update>

    <select id="searchBySuggestions" resultType="Student">
        select
            stu_real_name,
            stu_school,
            stu_college
        from t_student where is_delete = 1
    </select>

    <update id="deleteById" parameterType="integer">
        update t_student set is_delete = 0
        where id = #{id}
    </update>

    <update id="deleteSelect">
        update t_student set is_delete = 0
        where  id in
        <foreach collection="list" item="item" open="(" close=")" separator=",">
            #{item}
        </foreach>
    </update>

    <select id="getStuByStuName" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List" />
        from t_student
        where stu_name = #{stuName}
    </select>

    <select id="getStuByStuNum" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List" />
        from t_student
        where stu_number = #{stuNum}
    </select>

