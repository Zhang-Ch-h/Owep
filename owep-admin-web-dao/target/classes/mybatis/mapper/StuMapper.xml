    <result column="version" jdbcType="INTEGER" property="version"/>
</resultMap>

    <sql id="Base_Column_List">
        id, stu_name, stu_pwd, stu_number, stu_phone, stu_email, stu_real_name, email_code,
        gender, card_num, status, effective_date, birth, image_url, description, stu_type,
        stu_school, stu_college, stu_major, stu_education, english_level, perfect_status,
        is_delete, create_time, last_access_time, version
    </sql>

    <select id="selectAll" parameterType="java.lang.Integer" resultMap="BaseResultMap">
        select
        <include refid="Base_Column_List" />
        from t_student where is_delete = 1
    </select>

    <select id="selectClassByStuId" resultMap="StuClass">
        select s.id sid,
        stu_name,
        stu_pwd,
        stu_number,
        stu_phone,
        stu_email,
        stu_real_name,
        email_code,
        gender,
        card_num,
        status,
        effective_date,
        birth,
        image_url,
        description,
        stu_type,
        stu_school,
        stu_college,
        stu_major,
        stu_education,
        english_level,
        perfect_status,
        s.is_delete s_is_delete,
        s.create_time s_create_time,
        s.last_access_time s_last_access_time,
        s.version s_version,
        c.id cid,
        class_number,
        class_name,
        start_time,
        end_time,
        class_status,
        institute_name,
        branch_name,
        class_desc,
        teacher_name,
        c.is_delete c_is_delete,
        c.version c_version,
        c.create_time c_create_time,
        c.last_access_time c_last_access_time,
        old_class_name,
        old_class_num
        from t_student s left join t_class c on s.fk_class_id = c.id
        <where>
            <if test="stuId != null and stuId != 0">
                s.id = #{stuId}
            </if>
            and s.is_delete = 1 and c.is_delete = 1
        </where>
    </select>
